{
  "title": "Server Stats",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 99,
      "type": "histogram",
      "title": "Transaction Latency",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "displayName": "Latency (ms)",
          "color": {
            "mode": "fixed",
            "fixedColor": "#FF5733"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_transactions_latency_ms"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "options": {
        "showLegend": true,
        "showHistogram": true,
        "bucketSize": 5
      }
    },
    {
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
            "displayName": "network traffic",
            "color": {
                "mode": "fixed",
                "fixedColor": "yellow"
            }
        },
        "overrides": []
      },
      "title": "Network Receive Rate",
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total[1m])"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
            "displayName": "cpu",
            "color": {
                "mode": "fixed",
                "fixedColor": "cyan"
            }
        },
        "overrides": []
      },
      "title": "CPU Usage",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      }
    }
  ]
}
