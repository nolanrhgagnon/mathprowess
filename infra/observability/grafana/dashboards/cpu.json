{
  "title": "Server Stats",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "CPU Usage (Now)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Usage (Over Time)",
      "datasource": "Prometheus",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Network Receive Rate",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_network_receive_bytes_total[1m])"
        }
      ]
    },
    {
      "id": 4,
      "type": "histogram",
      "title": "Transaction Latency",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "displayName": "Latency (ms)"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_transactions_latency_ms"
        }
      ],
      "options": {
        "showLegend": true
      }
    }
  ]
}
